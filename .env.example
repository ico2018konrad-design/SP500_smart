# IBKR Connection
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1

# LLM APIs (optional - bot works without these)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=ant-...

# Telegram Alerts (optional)
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...

# FRED API (free - required for macro data)
FRED_API_KEY=...

# Mode
TRADING_MODE=paper
BOT_MODE=mini
